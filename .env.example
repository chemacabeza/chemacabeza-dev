# Content propagation — environment configuration (placeholders only).
# Copy to .env.local and fill in. NEVER commit real values; .env* is gitignored
# (this .env.example is the one tracked exception). Tokens are read ONLY from the
# environment and are never written to the sync state file or any artifact.

# Source of truth for canonical URLs (defaults to https://chemacabeza.dev).
SITE_BASE_URL=https://chemacabeza.dev

# --- Medium -----------------------------------------------------------------
# Medium's Publishing API is RETIRED. These are read only if you opt back in by
# also setting MEDIUM_API_BASE to a working endpoint; otherwise Medium runs in
# manual artifact mode (full-text draft generated for import via /p/import).
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_AUTHOR_ID=
# MEDIUM_API_BASE=

# --- LinkedIn ---------------------------------------------------------------
# Used by the LinkedIn adapter to post a FEED teaser (with explicit article
# link metadata) via the official Posts REST API. The full-text LinkedIn
# *article* has no public API and is always produced as a manual artifact.
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=urn:li:person:XXXXXXXX
# Optional: pin the dated API version (otherwise auto-detected).
# LINKEDIN_API_VERSION=

# --- Substack ---------------------------------------------------------------
# Substack has NO official public write API, so it runs in MANUAL OUTPUT MODE:
# the system generates a full-text, paste-ready draft and detects existing posts
# via the public RSS feed. Only the publication URL is needed (NOT a secret) —
# there is intentionally no SUBSTACK_API_TOKEN because no supported API exists.
SUBSTACK_PUBLICATION_URL=https://chemacabeza.substack.com
